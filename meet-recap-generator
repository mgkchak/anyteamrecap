<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Swim Meet Recap Generator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#07111f;--navy2:#0d1e33;--navy3:#162843;
  --blue:#2563eb;--blue-l:#3b82f6;
  --gold:#f59e0b;--gold-l:#fcd34d;
  --w:#f0f6ff;--w70:rgba(240,246,255,.7);--w40:rgba(240,246,255,.4);
  --w15:rgba(240,246,255,.15);--w08:rgba(240,246,255,.08);--w04:rgba(240,246,255,.04);
  --border:rgba(240,246,255,.12);
  --green:#10b981;--red:#ef4444;
  --ff:'DM Sans',sans-serif;--fd:'Playfair Display',serif;--fm:'DM Mono',monospace;
}
body{font-family:var(--ff);background:var(--navy);color:var(--w);min-height:100vh;line-height:1.6}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:repeating-linear-gradient(90deg,transparent,transparent calc(100%/8 - .5px),rgba(255,255,255,.02) calc(100%/8 - .5px),rgba(255,255,255,.02) calc(100%/8));}
.wrap{position:relative;z-index:1;max-width:900px;margin:0 auto;padding:2.5rem 1.5rem 5rem}
header{text-align:center;margin-bottom:2.5rem}
.brand{display:inline-flex;align-items:center;gap:.75rem;margin-bottom:.6rem}
.badge{width:40px;height:40px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:15px;font-weight:700;color:var(--navy)}
h1{font-family:var(--fd);font-size:clamp(1.5rem,4vw,2.35rem);font-weight:700;letter-spacing:-.02em}
.tagline{font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--w40);margin-top:.25rem}
.slabel{font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:.5rem;margin-top:1.5rem}
.slabel:first-of-type{margin-top:0}
.card{background:var(--w04);border:1px solid var(--border);border-radius:14px;padding:1.4rem;transition:border-color .2s,background .2s;margin-bottom:1.1rem}
.card.ok{border-color:rgba(16,185,129,.4);background:rgba(16,185,129,.04)}
.ctitle{font-size:.9rem;font-weight:500;margin-bottom:.2rem}
.csub{font-size:.76rem;color:var(--w40);line-height:1.45;margin-bottom:.9rem}
.tabs{display:flex;gap:.5rem;margin-bottom:1.1rem}
.tab{padding:.38rem .9rem;border-radius:7px;font-size:.78rem;font-weight:500;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--w40);transition:all .15s;font-family:var(--ff)}
.tab.active{background:var(--w08);border-color:var(--w15);color:var(--w)}
.tab:hover:not(.active){border-color:var(--w15);color:var(--w70)}
.paste-area{
  width:100%;min-height:160px;background:rgba(255,255,255,.04);
  border:1.5px dashed var(--border);border-radius:10px;
  padding:.85rem 1rem;font-family:var(--fm);font-size:.75rem;
  color:var(--w70);line-height:1.6;resize:vertical;outline:none;
  transition:border-color .2s;
}
.paste-area::placeholder{color:var(--w40)}
.paste-area:focus{border-color:var(--blue-l);border-style:solid}
.paste-area.has-content{border-color:rgba(16,185,129,.4);border-style:solid}
.upload-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem}
@media(max-width:560px){.upload-grid{grid-template-columns:1fr}}
.dz{border:1.5px dashed var(--border);border-radius:9px;padding:1.1rem;text-align:center;cursor:pointer;position:relative;transition:border-color .2s,background .2s}
.dz:hover,.dz.over{border-color:var(--blue-l);background:rgba(59,130,246,.06)}
.dz input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.dz-icon{font-size:1.3rem;margin-bottom:.3rem;color:var(--w40)}
.dz-txt{font-size:.76rem;color:var(--w40)}
.dz-txt b{color:var(--blue-l);font-weight:500}
.file-status{font-size:.75rem;margin-top:.6rem;display:none;align-items:center;gap:.4rem}
.file-status.show{display:flex}
.file-status.ok{color:var(--green)}
.file-status.err{color:var(--red)}
.hint{background:rgba(37,99,235,.07);border:1px solid rgba(59,130,246,.2);border-radius:10px;padding:.8rem 1rem;font-size:.78rem;color:rgba(147,197,253,.9);line-height:1.7;margin-bottom:1.1rem}
.hint strong{color:#93c5fd;font-weight:500}
.hint ol{padding-left:1.25rem;margin-top:.3rem}
.hint li{margin-bottom:.15rem}
.generate-row{display:flex;justify-content:center;margin:1.75rem 0 .5rem}
.gen-btn{padding:.8rem 2.5rem;background:var(--gold);border:none;border-radius:10px;color:var(--navy);font-family:var(--ff);font-size:.95rem;font-weight:600;cursor:pointer;transition:background .15s,transform .1s}
.gen-btn:hover{background:var(--gold-l)}
.gen-btn:active{transform:scale(.98)}
.gen-btn:disabled{background:var(--w15);color:var(--w40);cursor:not-allowed;transform:none}
.progress{display:none;text-align:center;color:var(--w70);font-size:.85rem;margin-bottom:1.25rem}
.progress.show{display:block}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid var(--w15);border-top-color:var(--gold);border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:.5rem}
@keyframes spin{to{transform:rotate(360deg)}}
.error-box{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.3);border-radius:10px;padding:.9rem 1.1rem;margin-bottom:1.1rem;font-size:.82rem;color:#fca5a5;display:none;white-space:pre-wrap}
.error-box.show{display:block}
.warn-box{background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.25);border-radius:10px;padding:.8rem 1.1rem;margin-bottom:1rem;font-size:.79rem;color:#fcd34d;display:none;line-height:1.7}
.warn-box.show{display:block}
.warn-box ul{list-style:none;padding:0}
.warn-box li::before{content:'⚠ '}
#output-section{display:none}
#output-section.show{display:block}
.output-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:.75rem}
.output-title{font-family:var(--fd);font-size:1.25rem;font-weight:700}
.btn-row{display:flex;gap:.6rem}
.btn-sm{padding:.42rem 1rem;border-radius:8px;font-family:var(--ff);font-size:.78rem;font-weight:500;cursor:pointer;transition:background .15s}
.btn-copy{background:var(--w08);border:1px solid var(--border);color:var(--w70)}
.btn-copy:hover{background:var(--w15)}
.btn-md{background:var(--gold);border:1px solid var(--gold);color:var(--navy)}
.btn-md:hover{background:var(--gold-l)}
.recap-box{background:var(--navy2);border:1px solid var(--border);border-radius:14px;padding:1.75rem 2rem;font-family:var(--fm);font-size:.82rem;line-height:2;color:var(--w70);white-space:pre-wrap;word-break:break-word;max-height:70vh;overflow-y:auto}
.recap-box::-webkit-scrollbar{width:5px}
.recap-box::-webkit-scrollbar-track{background:transparent}
.recap-box::-webkit-scrollbar-thumb{background:var(--w15);border-radius:3px}
.debug-toggle{font-size:.7rem;color:var(--w40);cursor:pointer;text-decoration:underline;text-underline-offset:2px;display:block;text-align:center;margin-top:.6rem}
.debug-box{background:var(--navy3);border:1px solid var(--border);border-radius:10px;padding:1rem;font-family:var(--fm);font-size:.7rem;color:var(--w40);white-space:pre-wrap;max-height:320px;overflow-y:auto;margin-top:.75rem;display:none}
.debug-box.show{display:block}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="brand">
      <div class="badge">🏊</div>
      <h1>Meet Recap Generator</h1>
    </div>
    <p class="tagline">MCSL Swim Meet Recap Generator</p>
  </header>

  <div class="slabel">Step 1 — Choose Input Method</div>
  <div class="tabs" id="mode-tabs">
    <button class="tab active" data-mode="paste" onclick="setMode('paste')">📋 Paste Results Page</button>
    <button class="tab" data-mode="pdf" onclick="setMode('pdf')">📄 Upload PDFs</button>
  </div>

  <!-- PASTE MODE -->
  <div id="mode-paste">
    <div class="card" id="team-selector-card" style="margin-bottom:1.1rem;display:none">
      <div class="ctitle">Select Your Team</div>
      <div class="csub">Choose which team to generate the recap for.</div>
      <div id="team-radio-group" style="display:flex;flex-wrap:wrap;gap:.6rem;margin-top:.5rem"></div>
    </div>

    <div class="hint">
      <strong>How to copy the meet results page:</strong>
      <ol>
        <li>Open your MCSL results page (e.g. <code>mcsl.org/display-results-dual/2025/week1/DA-WL</code>) while logged in</li>
        <li>Press <strong>Ctrl+A</strong> to select all, then <strong>Ctrl+C</strong> to copy</li>
        <li>Click in the box below and press <strong>Ctrl+V</strong> to paste</li>
      </ol>
      Seed times are pulled from the results page automatically — no separate file needed.
    </div>
    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem">
      <span style="font-size:.78rem;color:var(--w40);">Meet type:</span>
      <label style="display:flex;align-items:center;gap:.3rem;font-size:.82rem;cursor:pointer">
        <input type="radio" name="meettype" value="A" checked style="accent-color:var(--gold)"> A-Meet
      </label>
      <label style="display:flex;align-items:center;gap:.3rem;font-size:.82rem;cursor:pointer">
        <input type="radio" name="meettype" value="B" style="accent-color:var(--gold)"> B-Meet
      </label>
    </div>
    <textarea class="paste-area" id="paste-input" placeholder="Paste meet results text here…" oninput="onPasteInput()"></textarea>
    <div class="file-status" id="paste-status"></div>
  </div>

  <!-- PDF MODE -->
  <div id="mode-pdf" style="display:none">
    <div class="hint">
      Upload the official meet results PDF <strong>and</strong> the drops/seed times PDF.
    </div>
    <div class="upload-grid">
      <div class="card" id="card-results">
        <div class="ctitle">Meet Results PDF</div>
        <div class="csub">Official printed results for the meet.</div>
        <div class="dz" id="dz-results">
          <input type="file" accept=".pdf" onchange="handleFile('results',this)">
          <div class="dz-icon">📋</div>
          <div class="dz-txt"><b>Click or drag</b> PDF here</div>
        </div>
        <div class="file-status" id="status-results"></div>
      </div>
      <div class="card" id="card-drops">
        <div class="ctitle">Drops / Seed Times PDF</div>
        <div class="csub">Pre-meet seed times for Damascus swimmers.</div>
        <div class="dz" id="dz-drops">
          <input type="file" accept=".pdf" onchange="handleFile('drops',this)">
          <div class="dz-icon">⏱</div>
          <div class="dz-txt"><b>Click or drag</b> PDF here</div>
        </div>
        <div class="file-status" id="status-drops"></div>
      </div>
    </div>
  </div>

  <div class="warn-box" id="warn-box"><ul id="warn-list"></ul></div>
  <div class="error-box" id="error-box"></div>

  <div class="generate-row">
    <button class="gen-btn" id="gen-btn" onclick="generate()">⚡ Generate Recap</button>
  </div>
  <div class="progress" id="progress"><span class="spinner"></span><span id="prog-msg">Working…</span></div>

  <div id="output-section">
    <div class="output-header">
      <div class="output-title">Weekly Recap</div>
      <div class="btn-row">
        <button class="btn-sm btn-copy" onclick="copyRecap()">Copy Text</button>
        <button class="btn-sm btn-md" onclick="downloadMD()">⬇ Download .md</button>
      </div>
    </div>
    <div class="recap-box" id="recap-box"></div>
    <span class="debug-toggle" onclick="toggleDebug()">show parsing debug info</span>
    <div class="debug-box" id="debug-box"></div>
  </div>
</div>

<script>
pdfjsLib.GlobalWorkerOptions.workerSrc =
  'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

let mode = 'paste';
let pdfText = { results:'', drops:'' };
let debugLog = [];

// ── All-Star Standards ────────────────────────────────────────────────────────
function sec(t) {
  if (typeof t==='number') return t;
  t = String(t).trim();
  if (t.includes(':')) { const [m,s]=t.split(':'); return +m*60+parseFloat(s); }
  return parseFloat(t);
}
function fmtTime(s) {
  if (isNaN(s)||s<=0) return '—';
  if (s>=60) { const m=Math.floor(s/60),r=(s-m*60).toFixed(2).padStart(5,'0'); return `${m}:${r}`; }
  return s.toFixed(2);
}

const ALLSTAR = {
  '12U|IM':      {M:sec('1:20.00'),F:sec('1:21.00')},
  '13-14|IM':    {M:sec('1:12.60'),F:sec('1:17.60')},
  '15-18|IM':    {M:sec('1:07.00'),F:sec('1:14.00')},
  '8U|Free':     {M:20.25,F:20.55},
  '9-10|Free':   {M:35.80,F:36.35},
  '11-12|Free':  {M:31.40,F:32.70},
  '13-14|Free':  {M:28.40,F:31.00},
  '15-18|Free':  {M:sec('58.00'),F:sec('1:04.60')},
  '8U|Back':     {M:26.55,F:25.45},
  '9-10|Back':   {M:20.10,F:20.40},
  '11-12|Back':  {M:38.10,F:39.00},
  '13-14|Back':  {M:34.30,F:36.30},
  '15-18|Back':  {M:sec('1:08.00'),F:sec('1:15.00')},
  '8U|Breast':   {M:29.60,F:29.40},
  '9-10|Breast': {M:22.25,F:22.25},
  '11-12|Breast':{M:43.30,F:43.40},
  '13-14|Breast':{M:38.20,F:41.20},
  '15-18|Breast':{M:sec('1:16.25'),F:sec('1:25.00')},
  '8U|Fly':      {M:26.85,F:25.20},
  '9-10|Fly':    {M:18.70,F:18.60},
  '11-12|Fly':   {M:36.30,F:37.20},
  '13-14|Fly':   {M:32.00,F:34.10},
  '15-18|Fly':   {M:29.20,F:33.00},
};

// ── UI ────────────────────────────────────────────────────────────────────────
function setMode(m) {
  mode=m;
  document.getElementById('mode-paste').style.display=m==='paste'?'':'none';
  document.getElementById('mode-pdf').style.display=m==='pdf'?'':'none';
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('active',t.dataset.mode===m));
}
function onPasteInput() {
  const ta=document.getElementById('paste-input');
  const has=ta.value.trim().length>50;
  ta.classList.toggle('has-content',has);
  const st=document.getElementById('paste-status');
  if(has){
    st.textContent='✓ Content ready — click Generate';
    st.className='file-status show ok';
    populateTeamSelector(ta.value);
  } else {
    st.className='file-status';
    document.getElementById('team-selector-card').style.display='none';
  }
}

function populateTeamSelector(text) {
  // Extract team abbr+name pairs from pasted text
  const teams = [];
  const seen = new Set();
  const re = /([A-Z][A-Za-z\s]+?)\s*\(([A-Z]{2,3})\)\s*[	\s]+([\d]+\.?\d*)/g;
  let m;
  const fullText = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').replace(/\n/g,' ');
  while ((m = re.exec(fullText)) !== null) {
    const abbr = m[2], name = m[1].trim();
    if (!seen.has(abbr)) { seen.add(abbr); teams.push({abbr, name}); }
  }
  if (teams.length < 2) {
    document.getElementById('team-selector-card').style.display='none';
    return;
  }
  const grp = document.getElementById('team-radio-group');
  grp.innerHTML = teams.map((t,i) => `
    <label style="display:flex;align-items:center;gap:.4rem;font-size:.85rem;cursor:pointer;background:var(--w04);border:1px solid var(--border);border-radius:8px;padding:.4rem .75rem">
      <input type="radio" name="selectedteam" value="${t.abbr}" ${i===0?'checked':''} style="accent-color:var(--gold)">
      <strong style="color:var(--w)">${t.abbr}</strong>
      <span style="color:var(--w40)">${t.name}</span>
    </label>`).join('');
  document.getElementById('team-selector-card').style.display='block';
}
function setProgress(msg){document.getElementById('prog-msg').textContent=msg;document.getElementById('progress').className='progress show';}
function hideProgress(){document.getElementById('progress').className='progress';}
function showError(msg){const b=document.getElementById('error-box');b.textContent=msg;b.className='error-box show';}
function clearError(){document.getElementById('error-box').className='error-box';}
function showWarnings(msgs){
  const b=document.getElementById('warn-box'),ul=document.getElementById('warn-list');
  if(!msgs.length){b.className='warn-box';return;}
  ul.innerHTML=msgs.map(m=>`<li>${m}</li>`).join('');
  b.className='warn-box show';
}
function toggleDebug(){
  const d=document.getElementById('debug-box');
  d.className=d.className.includes('show')?'debug-box':'debug-box show';
}

// ── Drag & drop ───────────────────────────────────────────────────────────────
['dz-results','dz-drops'].forEach(id=>{
  const el=document.getElementById(id);if(!el)return;
  el.addEventListener('dragover',e=>{e.preventDefault();el.classList.add('over');});
  el.addEventListener('dragleave',()=>el.classList.remove('over'));
  el.addEventListener('drop',e=>{
    e.preventDefault();el.classList.remove('over');
    const f=e.dataTransfer.files[0];
    if(f)processFile(id==='dz-results'?'results':'drops',f);
  });
});
function handleFile(which,input){if(input.files[0])processFile(which,input.files[0]);}
async function processFile(which,file){
  if(!file.name.toLowerCase().endsWith('.pdf')){showFileStatus(which,'Must be a PDF',false);return;}
  showFileStatus(which,'Reading…',true);
  pdfText[which]=await extractPDF(file);
  showFileStatus(which,file.name,true);
  document.getElementById('card-'+which)?.classList.add('ok');
}
function showFileStatus(which,msg,ok){
  const el=document.getElementById('status-'+which);
  el.textContent=(ok?'✓ ':'✗ ')+msg;
  el.className='file-status show '+(ok?'ok':'err');
}

// ── PDF extraction ────────────────────────────────────────────────────────────
async function extractPDF(file) {
  const ab=await file.arrayBuffer();
  const pdf=await pdfjsLib.getDocument({data:ab}).promise;
  let out='';
  for(let p=1;p<=pdf.numPages;p++){
    const page=await pdf.getPage(p);
    const content=await page.getTextContent();
    const rows={};
    for(const item of content.items){
      const y=Math.round(item.transform[5]);
      if(!rows[y])rows[y]=[];
      rows[y].push({x:item.transform[4],str:item.str});
    }
    const ys=Object.keys(rows).map(Number).sort((a,b)=>b-a);
    for(const y of ys){
      out+=rows[y].sort((a,b)=>a.x-b.x).map(r=>r.str).join('\t')+'\n';
    }
    out+='\n';
  }
  return out;
}

// ── NAME helpers ──────────────────────────────────────────────────────────────
// "Zhao, Marc" or "Zhao, Marc R" → "Marc Zhao"  (drop middle initial)
function flipName(raw) {
  raw = raw.trim();
  if (raw.includes(',')) {
    const comma = raw.indexOf(',');
    const last  = raw.slice(0, comma).trim();
    // everything after comma; strip trailing middle initial like " R" or " D"
    let first = raw.slice(comma+1).trim().replace(/\s+[A-Z]\.?$/, '').trim();
    return `${first} ${last}`;
  }
  return raw;
}

// ── MCSL page parser ──────────────────────────────────────────────────────────
/*
  Exact format observed:

  2025 Week 1 Dual Meet Damascus at Westleigh
  Team           Score
  Damascus (DA)  405.5
  Westleigh (WL) 379.5

  Event 1 - Male 12&U 100M Medley
  Seed Time  Final Time  Points
  1  Joung, Joshua S (12)(WL)  1:11.82  1:12.44  6
  2  Brock, Paxton C (12)(WL)  1:14.77  1:15.94  4
  ...
  4  Zhao, Marc (10)(DA)        1:33.07  1:34.75  2

  Event 2 - Female 12&U 100M Medley
  ...

  Notes:
  - Place number is first token on entry line (no label)
  - Swimmer: "Last, First [MI] (age)(TEAM)"
  - Two times follow: seed, final
  - Points last
  - DQ entries: "DQ  Name (age)(TEAM)  seed  DQ"
*/

function parseMeetPage(text) {
  debugLog = [];
  const lines = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n').map(l=>l.trim()).filter(Boolean);
  const meet = { meetName:'', daAbbr:'DA', oppName:'', daScore:null, oppScore:null, teams:[], events:[] };

  // ── Meet title: "2025 Week 1 Dual Meet Damascus at Westleigh"
  for (const l of lines) {
    if (/week\s*\d/i.test(l) && /meet/i.test(l)) {
      meet.meetName = l.replace(/\s+/g,' ').trim();
      break;
    }
  }
  debugLog.push('Meet title: ' + meet.meetName);

  // ── Team scores: "Damascus (DA)  405.5" style lines
  // Also handle tab-separated: "Damascus (DA)\t405.5"
  for (const l of lines) {
    const m = l.match(/^([A-Z][A-Za-z\s]+?)\s*\(([A-Z]{2,3})\)\s*[\t\s]+([\d]+\.?\d*)$/);
    if (m) {
      const name=m[1].trim(), abbr=m[2], score=parseFloat(m[3]);
      meet.teams.push({name, abbr, score});
      if (/damascus/i.test(name) || abbr==='DA') {
        meet.daAbbr=abbr; meet.daScore=score;
      } else {
        meet.oppName=name; meet.oppScore=score;
      }
    }
  }
  // Fallback: scan for score patterns in same line "Damascus (DA) 405.5 Westleigh (WL) 379.5"
  if (meet.daScore===null) {
    const joined = lines.join(' ');
    const m = joined.match(/Damascus\s*\(DA\)\s+([\d.]+).*?(\w[\w\s]+?)\s*\(([A-Z]{2,3})\)\s+([\d.]+)/i);
    if (m) { meet.daScore=parseFloat(m[1]); meet.oppName=m[2].trim(); meet.oppScore=parseFloat(m[4]); }
  }
  debugLog.push(`DA: ${meet.daAbbr} ${meet.daScore}  Opp: ${meet.oppName} ${meet.oppScore}`);

  // ── Events
  // Header: "Event N - [Male/Female] [AgeGroup] [Distance]M [Stroke]"
  //    or   "Event N - [Male/Female] [AgeGroup] [Distance]M [Stroke]"
  const eventRe = /^event\s+(\d+)\s*[-–]?\s*(.+)/i;

  let cur = null;

  for (const line of lines) {
    // ── Event header?
    const evM = line.match(eventRe);
    if (evM) {
      if (cur) meet.events.push(cur);
      cur = { ...parseEventInfo(evM[2]), eventNum:+evM[1], entries:[] };
      debugLog.push(`Ev ${evM[1]}: gender=${cur.gender} age=${cur.ageGroup} dist=${cur.distance} stroke=${cur.stroke}`);
      continue;
    }

    // ── Skip column-header rows
    if (/^(seed\s*time|final\s*time|place|name|pts|points|heat|lane)\b/i.test(line)) continue;

    if (!cur) continue;

    // ── Entry line?
    // Must start with a place number or DQ/NS
    if (!/^(\d+|DQ|NS|SCR|DSQ)\b/i.test(line)) continue;

    const entry = parseEntryLine(line);
    if (entry) {
      cur.entries.push(entry);
      if (cur.entries.length <= 2) debugLog.push(`  entry: ${JSON.stringify(entry)}`);
    }
  }
  if (cur) meet.events.push(cur);

  debugLog.push(`Total events: ${meet.events.length}`);
  const daCount = meet.events.reduce((s,e)=>s+e.entries.filter(x=>x.team===meet.daAbbr).length,0);
  debugLog.push(`Total DA entries: ${daCount}`);

  return meet;
}

// ── Event header parser ───────────────────────────────────────────────────────
function parseEventInfo(str) {
  str = str.replace(/\s+/g,' ').trim();

  // Gender
  let gender='U';
  const gm = str.match(/^(female|male|girls?|boys?|mixed)/i);
  if (gm) {
    const g=gm[0].toLowerCase();
    gender = (g==='female'||g.startsWith('girl')) ? 'F' : (g==='male'||g.startsWith('boy')) ? 'M' : 'X';
    str = str.slice(gm[0].length).trim();
  }

  // Age group: "12&U", "12 & Under", "8&U", "8 & Under", "9-10", "11-12", "13-14", "15-18"
  let ageGroup='';
  const agm = str.match(/^(8\s*[&]\s*[Uu](?:nder)?|12\s*[&]\s*[Uu](?:nder)?|8U|12U|9[-–]10|11[-–]12|13[-–]14|15[-–]18)/i);
  if (agm) {
    const raw=agm[0].replace(/\s/g,'').toLowerCase();
    if (raw.startsWith('8')) ageGroup='8U';
    else if (raw.startsWith('12')) ageGroup='12U';
    else ageGroup=raw.replace(/–/g,'-').replace(/under/i,'').replace(/[^0-9\-]/g,'');
    str=str.slice(agm[0].length).trim();
  }

  // Distance: "100M", "50M", "25M"
  let distance='';
  const dm=str.match(/^(\d+)\s*[Mm]/);
  if (dm) { distance=dm[1]; str=str.slice(dm[0].length).trim(); }

  const stroke=strokeFrom(str);
  return {gender,ageGroup,distance,stroke};
}

function strokeFrom(s) {
  s=s.trim().toLowerCase();
  if (/free/i.test(s)) return 'Free';
  if (/back/i.test(s)) return 'Back';
  if (/breast/i.test(s)) return 'Breast';
  if (/fly|butterfly/i.test(s)) return 'Fly';
  if (/medley|individual|\bim\b/i.test(s)) return 'IM';
  return s.charAt(0).toUpperCase()+s.slice(1);
}

// ── Entry line parser ─────────────────────────────────────────────────────────
/*
  Input examples:
    "4  Zhao, Marc (10)(DA)  1:33.07  1:34.75  2"
    "1  Joung, Joshua S (12)(WL)  1:11.82  1:12.44  6"
    "DQ  Smith, Jane (9)(DA)  45.20  DQ"
    "6  Griffith, Caleb R (9)(DA)  1:47.75  1:41.00  0"

  Strategy: extract team tag (XX) last, then work backward for times, then name.
*/
function parseEntryLine(line) {
  // 1. Place
  const placeM = line.match(/^(\d+|DQ|NS|SCR|DSQ)\s+/i);
  if (!placeM) return null;
  const place = isNaN(+placeM[1]) ? placeM[1].toUpperCase() : +placeM[1];
  let rest = line.slice(placeM[0].length).trim();

  // 2. Extract team from "(DA)" or "(WL)" pattern — last such occurrence near name
  //    Format: "Last, First [MI] (age)(TEAM)"
  //    Team is always the last parenthetical before the times
  const teamM = rest.match(/\(([A-Z]{2,3})\)(?=\s|$|\t)/);
  if (!teamM) return null;
  const team = teamM[1];

  // 3. Everything up to and including (TEAM) is the name block
  const nameEnd = rest.indexOf(teamM[0]) + teamM[0].length;
  const nameBlock = rest.slice(0, nameEnd);
  rest = rest.slice(nameEnd).trim();

  // 4. Extract just the name — strip age "(12)" and team "(DA)" from nameBlock
  //    "Zhao, Marc (10)(DA)" → "Zhao, Marc"
  const rawName = nameBlock.replace(/\(\d+\)/g,'').replace(/\([A-Z]{2,3}\)/g,'').trim();
  const name = flipName(rawName);

  // 5. Parse times from rest — could be tabs or spaces
  //    Expect: seedTime  finalTime  points
  //    or:     seedTime  DQ
  const tokens = rest.split(/\s{2,}|\t+/).map(s=>s.trim()).filter(Boolean);
  const timeRe = /^((?:\d+:)?\d{1,2}\.\d{2})$/;
  const dqRe   = /^(DQ|NS|SCR|DSQ)$/i;
  // Points: a plain integer (no colon, no decimal point in the swimmer-time sense)
  // It appears as the LAST token after all times. Values 0-6 per event.
  const ptsRe  = /^\d+$/;

  let seedSec=null, finalSec=null, finalStr='', points=0;

  const timeTokens = tokens.filter(t=>timeRe.test(t));
  const dqTokens   = tokens.filter(t=>dqRe.test(t));

  if (timeTokens.length>=2) {
    seedSec  = sec(timeTokens[0]);
    finalSec = sec(timeTokens[1]);
    finalStr = timeTokens[1];
  } else if (timeTokens.length===1) {
    if (dqTokens.length) {
      seedSec  = sec(timeTokens[0]);
      finalStr = dqTokens[0].toUpperCase();
    } else {
      finalSec = sec(timeTokens[0]);
      finalStr = timeTokens[0];
    }
  }

  // Points = last token that is a plain integer (after times are accounted for)
  const lastToken = tokens[tokens.length-1];
  if (lastToken && ptsRe.test(lastToken) && !timeRe.test(lastToken)) {
    points = parseInt(lastToken, 10);
  }

  return {place, name, team, seedSec, finalSec, finalStr, points};
}

// ── Drops PDF parser ──────────────────────────────────────────────────────────
// For PDF mode: returns { "First Last": { "Free":sec, "Back":sec, ... } }
function parseDropsPDF(text) {
  const map={};
  const lines=text.split('\n').map(l=>l.trim()).filter(Boolean);
  for (const line of lines) {
    // Tab-separated: Name \t EventDesc \t Time
    const parts=line.split(/\t+/).map(s=>s.trim()).filter(Boolean);
    if (parts.length>=3) {
      const timePart=parts.find(p=>/^((?:\d+:)?\d{1,2}\.\d{2})$/.test(p));
      if (timePart) {
        const name=flipName(parts[0]);
        const stroke=strokeFrom(parts.slice(1,parts.indexOf(timePart)).join(' '));
        if (!map[name])map[name]={};
        map[name][stroke]=sec(timePart);
        continue;
      }
    }
    // Space-separated fallback
    const m=line.match(/^([A-Za-z][A-Za-z',.\s-]+?)\s{2,}(.+?)\s{2,}((?:\d+:)?\d{1,2}\.\d{2})\s*$/);
    if (m) {
      const name=flipName(m[1]);
      const stroke=strokeFrom(m[2]);
      if (!map[name])map[name]={};
      map[name][stroke]=sec(m[3]);
    }
  }
  debugLog.push('Drops entries: '+Object.keys(map).length);
  return map;
}

function lookupSeed(name, stroke, dropsMap) {
  if (!dropsMap) return null;
  const try1=dropsMap[name];
  if (try1&&try1[stroke]!==undefined) return try1[stroke];
  // fuzzy: last name match
  const last=name.split(' ').pop().toLowerCase();
  for (const [k,v] of Object.entries(dropsMap)) {
    if (k.split(' ').pop().toLowerCase()===last && v[stroke]!==undefined) return v[stroke];
  }
  return null;
}

// ── Main generate ─────────────────────────────────────────────────────────────
async function generate() {
  clearError(); showWarnings([]);
  document.getElementById('output-section').className='';
  debugLog=[];

  let meetText='', dropsMap=null;

  if (mode==='paste') {
    meetText=document.getElementById('paste-input').value;
    if (meetText.trim().length<50){showError('Please paste the meet results first.');return;}
  } else {
    if (!pdfText.results){showError('Please upload the meet results PDF.');return;}
    if (!pdfText.drops)  {showError('Please upload the drops/seed times PDF.');return;}
    meetText=pdfText.results;
    dropsMap=parseDropsPDF(pdfText.drops);
  }

  document.getElementById('gen-btn').disabled=true;
  setProgress('Parsing meet results…');

  try {
    const meet=parseMeetPage(meetText);
    // Override daAbbr if user selected a team
    const selectedRadio = document.querySelector('input[name=selectedteam]:checked');
    if (selectedRadio) meet.daAbbr = selectedRadio.value;
    setProgress('Computing recap…');
    const recap=buildRecap(meet,dropsMap);
    document.getElementById('debug-box').textContent=debugLog.join('\n');
    document.getElementById('recap-box').textContent=recap;
    document.getElementById('output-section').className='show';
    hideProgress();
  } catch(e) {
    hideProgress();
    showError('Error: '+e.message);
    console.error(e);
    document.getElementById('debug-box').textContent=debugLog.join('\n')+'\n\nERROR: '+e.stack;
    document.getElementById('output-section').className='show';
    document.getElementById('recap-box').textContent='';
  }
  document.getElementById('gen-btn').disabled=false;
}

// ── Recap builder ─────────────────────────────────────────────────────────────
function buildRecap(meet, dropsMap) {
  const {meetName,events}=meet;
  const daAbbr=meet.daAbbr;
  // Find selected team and opponent from teams array
  const daTeamObj  = meet.teams.find(t=>t.abbr===daAbbr) || {name:daAbbr, score:meet.daScore};
  const oppTeamObj = meet.teams.find(t=>t.abbr!==daAbbr) || {name:meet.oppName, score:meet.oppScore};
  const daScore  = daTeamObj.score;
  const oppScore = oppTeamObj.score;
  const oppName  = oppTeamObj.name;

  // Build swimmer map: name → {gender,ageGroup,totalPoints,firstPlaces,results[]}
  const swimmerMap={};

  for (const ev of events) {
    for (const en of ev.entries) {
      if (en.team!==daAbbr) continue;
      if (!en.finalSec||en.finalSec<=0) continue;

      if (!swimmerMap[en.name]) {
        swimmerMap[en.name]={gender:ev.gender,ageGroup:ev.ageGroup,totalPoints:0,firstPlaces:0,results:[]};
      }
      const sw=swimmerMap[en.name];
      sw.totalPoints+=en.points;
      if (en.place===1) sw.firstPlaces++;

      // Seed: inline from page (paste mode) or from dropsMap (PDF mode)
      let seedSec=en.seedSec;
      if ((seedSec===null||seedSec===undefined)&&dropsMap) {
        seedSec=lookupSeed(en.name,ev.stroke,dropsMap);
      }

      sw.results.push({
        stroke:ev.stroke, distance:ev.distance,
        ageGroup:ev.ageGroup, gender:ev.gender,
        finalSec:en.finalSec, finalStr:en.finalStr,
        seedSec, place:en.place
      });
    }
  }

  debugLog.push(`DA swimmers: ${Object.keys(swimmerMap).length}`);
  if (Object.keys(swimmerMap).length>0)
    debugLog.push('Sample: '+JSON.stringify(Object.entries(swimmerMap)[0]));

  // ── Drops
  const swimmerDrops={}; // name → {stroke→dropSec}
  const allDropEvents=[];

  for (const [name,sw] of Object.entries(swimmerMap)) {
    swimmerDrops[name]={};
    for (const r of sw.results) {
      if (r.seedSec&&r.seedSec>0&&r.finalSec>0) {
        const d=r.seedSec-r.finalSec;
        if (d>0) {
          swimmerDrops[name][r.stroke]=(swimmerDrops[name][r.stroke]||0)+d;
          allDropEvents.push({name,stroke:r.stroke,dropSec:d});
        }
      }
    }
  }

  // Combined drop per swimmer
  const combinedDrop={};
  for (const [name,sm] of Object.entries(swimmerDrops)) {
    const total=Object.values(sm).reduce((a,b)=>a+b,0);
    if (total>0) combinedDrop[name]={total,strokes:Object.keys(sm)};
  }

  // ── All-Star qualifiers
  const quals=[];
  const qualSeen=new Set();
  for (const ev of events) {
    for (const en of ev.entries) {
      if (en.team!==daAbbr||!en.finalSec||en.finalSec<=0) continue;
      const key=`${ev.ageGroup}|${ev.stroke}`;
      const std=ALLSTAR[key];
      if (!std) continue;
      const g=ev.gender==='F'?'F':'M';
      const cut=std[g];
      if (cut&&en.finalSec<=cut) {
        const qk=en.name+'|'+key;
        if (!qualSeen.has(qk)){
          qualSeen.add(qk);
          quals.push({name:en.name,event:`${ev.distance}M ${ev.stroke}`,time:en.finalStr,stroke:ev.stroke});
        }
      }
    }
  }

  // ── Personal bests
  const pbCount=allDropEvents.length;
  const biggest=allDropEvents.sort((a,b)=>b.dropSec-a.dropSec)[0]||null;

  // ── Drop buckets (floor seconds ≥2)
  const buckets={};
  for (const [name,sm] of Object.entries(swimmerDrops)) {
    for (const [stroke,d] of Object.entries(sm)) {
      if (d<2) continue;
      const b=Math.floor(d);
      if (!buckets[b])buckets[b]=[];
      buckets[b].push({name,stroke});
    }
  }

  // ── Top scorers
  function topScore(list) {
    if (!list.length) return null;
    const top=list[0][1].totalPoints;
    const tied=list.filter(([,v])=>v.totalPoints===top);
    return {names:tied.map(([n])=>n),pts:top,fp:tied[0][1].firstPlaces};
  }
  const girls=Object.entries(swimmerMap).filter(([,v])=>v.gender==='F').sort((a,b)=>b[1].totalPoints-a[1].totalPoints);
  const boys =Object.entries(swimmerMap).filter(([,v])=>v.gender==='M').sort((a,b)=>b[1].totalPoints-a[1].totalPoints);
  const topG=topScore(girls), topB=topScore(boys);

  // Most improved: 3+ event drops, top 5 by combined total
  const mostImproved=Object.entries(combinedDrop)
    .filter(([,info])=>info.strokes.length>=3)
    .sort((a,b)=>b[1].total-a[1].total)
    .slice(0,5);

  // ── Warnings
  const warns=[];
  if (events.length===0) warns.push('No events detected — format may not match expected MCSL layout.');
  if (Object.keys(swimmerMap).length===0) warns.push(`No ${daAbbr} swimmer entries found. If you selected the wrong team, use the team selector above.`);
  const seedCount=Object.values(swimmerDrops).reduce((a,b)=>a+Object.keys(b).length,0);
  if (seedCount===0&&Object.keys(swimmerMap).length>0)
    warns.push('No seed times found — drops section will be empty. Check that the results page includes a Seed Time column.');
  showWarnings(warns);

  // ── Format helpers
  const nameList=arr=>arr.length<=1?arr[0]:arr.slice(0,-1).join(', ')+' and '+arr.slice(-1)[0];
  const strokeList=arr=>{
    const u=[...new Set(arr)];
    if(u.length===1)return u[0];
    if(u.length===2)return u[0]+' and '+u[1];
    return u.slice(0,-1).join(', ')+', and '+u.slice(-1)[0];
  };

  // ── Build output string
  let o='';
  const mName=meetName||'Meet Recap';
  const da=daScore!==null?daScore:'???';
  const os=oppScore!==null?oppScore:'???';
  const opp=oppName?oppName.toUpperCase():'OPPONENT';

  // Format title: extract week number and A/B designation
  // meetName e.g. "2025 Week 1 Dual Meet Damascus at Westleigh" or "2025 Week 1A Dual Meet..."
  const weekM = mName.match(/week\s*(\d+)\s*([AB])?/i);
  const weekNum = weekM ? weekM[1] : '?';
  const radioVal = (document.querySelector('input[name=meettype]:checked')||{value:'A'}).value;
  const weekLetter = weekM && weekM[2] ? weekM[2].toUpperCase() : radioVal;
  const daTeamName = (daTeamObj?.name || daAbbr).toUpperCase();
  const formattedTitle = `Week ${weekNum} ${weekLetter}-Meet: ${daTeamName} (${da}) VS ${opp} (${os})`;
  o+=formattedTitle+'\n\n';

  o+=`Top 5 Most Improved\n`;
  if (mostImproved.length) {
    for (const [name,info] of mostImproved)
      o+=`${name} dropped a combined ${info.total.toFixed(2)} seconds across ${strokeList(info.strokes)}\n`;
  } else { o+=`(No seed time data available)\n`; }
  o+='\n';

  o+=`Top Point Scorers\n`;
  if (topG) {
    const fp=topG.fp;
    const each=topG.names.length>1?' each':'';
    o+=`Girls - ${nameList(topG.names)} with ${topG.pts} points and ${fp} first place finish${fp!==1?'es':''}${each}\n`;
  }
  if (topB) {
    const fp=topB.fp;
    const each=topB.names.length>1?' each':'';
    o+=`Boys - ${nameList(topB.names)} with ${topB.pts} points and ${fp} first place finish${fp!==1?'es':''}${each}\n`;
  }
  if (!topG&&!topB) o+=`(No scoring data found)\n`;
  o+='\n';

  o+=`All-Star Qualifiers\n`;
  if (quals.length) {
    for (const q of quals) o+=`${q.name} - ${q.event} - ${q.time}\n`;
  } else { o+=`(None this meet)\n`; }
  o+='\n';

  o+=`Personal Bests\n`;
  o+=`We had ${pbCount} new personal best${pbCount!==1?'s':''} across the team.\n`;
  if (biggest) o+=`\nBiggest drop: ${biggest.name} dropped ${biggest.dropSec.toFixed(2)} in ${biggest.stroke}\n`;
  o+='\n';

  const maxB=Object.keys(buckets).length?Math.max(...Object.keys(buckets).map(Number)):1;
  for (let b=2;b<=maxB;b++) {
    if (!buckets[b]||!buckets[b].length) continue;
    o+=`${b}-Second Drops\n`;
    for (const e of buckets[b]) o+=`${e.name} - ${e.stroke}\n`;
    o+='\n';
  }

  return o.trimEnd();
}

// ── Export ────────────────────────────────────────────────────────────────────
function copyRecap(){
  navigator.clipboard.writeText(document.getElementById('recap-box').textContent).then(()=>{
    const b=document.querySelector('.btn-copy');b.textContent='Copied!';
    setTimeout(()=>b.textContent='Copy Text',2000);
  });
}
function downloadMD(){
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([document.getElementById('recap-box').textContent],{type:'text/markdown'}));
  a.download='meet-recap.md';a.click();
}
