// Populate team dropdowns
function initTeamDropdowns() {
  const opts = MCSL_TEAMS.map(t=>`<option value="${t.abbr}">${t.name} (${t.abbr})</option>`).join('');
  document.getElementById('b-home-team').innerHTML += opts;
  document.getElementById('b-away-team').innerHTML += opts;

}
document.addEventListener('DOMContentLoaded', initTeamDropdowns);


// ── All-Star Standards ────────────────────────────────────────────────────────
function sec(t) {
  if (typeof t==='number') return t;
  t = String(t).trim();
  if (t.includes(':')) { const [m,s]=t.split(':'); return +m*60+parseFloat(s); }
  return parseFloat(t);
}
function fmtTime(s) {
  if (isNaN(s)||s<=0) return '—';
  if (s>=60) { const m=Math.floor(s/60),r=(s-m*60).toFixed(2).padStart(5,'0'); return `${m}:${r}`; }
  return s.toFixed(2);
}

