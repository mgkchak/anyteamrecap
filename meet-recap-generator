<body>
<div class="wrap">
  <header>
    <div class="brand">
      <div class="badge" style="font-size:20px;background:var(--gold)">🏊</div>
      <h1>Meet Recap Generator</h1>
    </div>
    <p class="tagline">Montgomery County Swim League · MCSL</p>
  </header>

  <div class="slabel">Step 1 — Choose Input Method</div>
  <div class="tabs" id="mode-tabs">
    <button class="tab active" data-mode="paste" onclick="setMode('paste')">📋 A-Meet (Paste Results)</button>
    <button class="tab" data-mode="pdf" onclick="setMode('pdf')">📄 B-Meet (Upload PDF)</button>
  </div>

  <!-- PASTE MODE -->
  <div id="mode-paste">
    <div class="hint">
      <strong>How to copy the meet results:</strong>
      <ol>
        <li>Visit <strong>mcsl.org</strong>, select <strong>Meet Results</strong> from the left-hand menu, then select the year and week</li>
        <li>Scroll down to the meet you want, then click to open it</li>
        <li>Select everything from <strong>20XX Week [#] Dual Meet [Team] at [Team]</strong> at the top all the way through the last result at the bottom of the page</li>
        <li>Copy (<strong>Ctrl+C</strong>), then paste below (<strong>Ctrl+V</strong>)</li>
      </ol>
    </div>
    <textarea class="paste-area" id="paste-input" placeholder="Paste meet results text here…" oninput="onPasteInput()"></textarea>
    <div class="file-status" id="paste-status"></div>

    <!-- Team selectors: revealed after paste, populated from detected teams -->
    <div id="a-team-selectors" style="display:none;margin-top:1rem">
      <div class="team-row" style="margin-bottom:.75rem">
        <div class="team-field">
          <label>Home Team <span style="color:var(--gold);font-weight:600">@ (at)</span></label>
          <select class="mcsl-select" id="a-home-team">
            <option value="">Select home team…</option>
          </select>
        </div>
        <div class="at-label">vs</div>
        <div class="team-field">
          <label>Away Team</label>
          <select class="mcsl-select" id="a-away-team">
            <option value="">Select away team…</option>
          </select>
        </div>
      </div>
      <div class="team-field" style="margin-bottom:.5rem">
        <label>Generate recap for</label>
        <select class="mcsl-select" id="a-recap-team">
          <option value="">Select team to recap…</option>
        </select>
      </div>
    </div>
  </div>

  <!-- PDF MODE (B-Meet) -->
  <div id="mode-pdf" style="display:none">
    <div class="hint">
      Upload the meet recap PDF. Teams will be detected automatically from the file.
    </div>

    <!-- PDF upload first -->
    <div class="card" id="card-bmeet">
      <div class="ctitle">B-Meet PDF</div>
      <div class="csub">Upload the meet recap PDF. Teams will be detected automatically from the file.</div>
      <div class="dz" id="dz-bmeet">
        <input type="file" accept=".pdf" onchange="handleFile('bmeet',this)">
        <div class="dz-icon">📋</div>
        <div class="dz-txt"><b>Click or drag</b> PDF here</div>
      </div>
      <div class="file-status" id="status-bmeet"></div>
    </div>

    <!-- Team selectors: revealed after PDF upload, populated from detected teams -->
    <div id="b-team-selectors" style="display:none">
      <div class="team-row" style="margin-bottom:.75rem">
        <div class="team-field">
          <label>Home Team <span style="color:var(--gold);font-weight:600">@ (at)</span></label>
          <select class="mcsl-select" id="b-home-team">
            <option value="">Select home team…</option>
          </select>
        </div>
        <div class="at-label">vs</div>
        <div class="team-field">
          <label>Away Team</label>
          <select class="mcsl-select" id="b-away-team">
            <option value="">Select away team…</option>
          </select>
        </div>
      </div>
      <div class="team-field" style="margin-bottom:1rem">
        <label>Generate recap for</label>
        <select class="mcsl-select" id="b-recap-team">
          <option value="">Select team to recap…</option>
        </select>
      </div>
    </div>
  </div>

  <div class="warn-box" id="warn-box"><ul id="warn-list"></ul></div>
  <div class="error-box" id="error-box"></div>

  <div class="generate-row">
    <button class="gen-btn" id="gen-btn" onclick="generate()">⚡ Generate Recap</button>
  </div>
  <div class="progress" id="progress"><span class="spinner"></span><span id="prog-msg">Working…</span></div>

  <div id="output-section">
    <div class="output-header">
      <div class="output-title">Weekly Recap</div>
      <div class="btn-row">
        <button class="btn-sm btn-copy" onclick="copyRecap()">Copy Text</button>
        <button class="btn-sm btn-md" onclick="downloadMD()">⬇ Download .md</button>
      </div>
    </div>
    <div class="recap-box" id="recap-box"></div>
    <span class="debug-toggle" onclick="toggleDebug()">show parsing debug info</span>
    <div class="debug-box" id="debug-box"></div>
  </div>
  <footer style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border);text-align:center;font-size:.72rem;color:var(--w40);line-height:1.7">
    Created by Melanie Kurimchak in collaboration with Claude Sonnet 4.6 (Anthropic).<br>
    Melanie conceived the tool, defined all requirements, tested functionality, and directed development through iterative feedback.
  </footer>
</div>

