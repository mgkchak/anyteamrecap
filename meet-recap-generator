// ── PDF extraction ────────────────────────────────────────────────────────────
async function extractPDF(file) {
  const ab=await file.arrayBuffer();
  const pdf=await pdfjsLib.getDocument({data:ab}).promise;
  let out='';
  for(let p=1;p<=pdf.numPages;p++){
    const page=await pdf.getPage(p);
    const content=await page.getTextContent();

    // Group items into rows using y-tolerance of 3px to handle
    // sub-pixel rendering differences in columnar PDFs
    const items = content.items.map(item=>({
      x: item.transform[4],
      y: item.transform[5],
      str: item.str
    }));

    // Sort all items top-to-bottom
    items.sort((a,b)=>b.y-a.y);

    // Group into rows: items within 3px vertically go on the same row
    const rows=[];
    for(const item of items){
      const lastRow=rows[rows.length-1];
      if(lastRow && Math.abs(item.y - lastRow.y) <= 3){
        lastRow.items.push(item);
      } else {
        rows.push({y:item.y, items:[item]});
      }
    }

    // Sort each row left-to-right and join with tab
    for(const row of rows){
      const ligNorm = s => s.replace(/[\u03B2\u03D0\uFB00-\uFB06]/g, m => (
        {'\uFB00':'ff','\uFB01':'fi','\uFB02':'fl','\uFB03':'ffi',
         '\uFB04':'ffl','\uFB05':'st','\uFB06':'st','\u03B2':'fi','\u03D0':'fi'}[m]||m));
      const rawLine=row.items.sort((a,b)=>a.x-b.x).map(i=>ligNorm(i.str)).join('\t');
      // Collapse tabs between word fragments (mid-word ligature splits like "Grif\tfi\tin")
      // A tab is a mid-word split if both neighbors are non-space, non-digit word chars
      const line=rawLine.replace(/([A-Za-z])\t([A-Za-z])/g,'$1$2').replace(/([A-Za-z])\t([A-Za-z])/g,'$1$2');
      if(line.trim()) out+=line+'\n';
    }
    out+='\n';
  }
  return out;
}

// ── NAME helpers ──────────────────────────────────────────────────────────────
// "Zhao, Marc" or "Zhao, Marc R" → "Marc Zhao"  (drop middle initial)
function flipName(raw) {
  raw = raw.trim();
  if (raw.includes(',')) {
    const comma = raw.indexOf(',');
    const last  = raw.slice(0, comma).trim();
    // Strip trailing middle initial like " R" or " D"
    let first = raw.slice(comma+1).trim().replace(/\s+[A-Z]\.?$/, '').trim();
    // Strip duplicate: if last word of first-part matches last word of last-name, remove it
    // e.g. "Benjamin Fideli" + "Fensterseifer Fideli" → drop trailing "Fideli" from first
    const lastNameLastWord = last.split(/\s+/).pop().toLowerCase();
    const firstParts = first.split(/\s+/);
    if (firstParts.length > 1 && firstParts[firstParts.length-1].toLowerCase() === lastNameLastWord) {
      first = firstParts.slice(0,-1).join(' ');
    }
    return `${first} ${last}`;
  }
  return raw;
}

// ── MCSL page parser ──────────────────────────────────────────────────────────
/*
  Exact format observed:

  2025 Week 1 Dual Meet TeamA at TeamB
  Team           Score
  TeamA (AB)  405.5
  TeamB (CD)  379.5

  Event 1 - Male 12&U 100M Medley
  Seed Time  Final Time  Points
  1  Smith, John A (12)(AB)  1:11.82  1:12.44  6
  2  Jones, Amy B (11)(CD)   1:14.77  1:15.94  4
  ...
  4  Lee, Sam C (10)(AB)     1:33.07  1:34.75  2

  Event 2 - Female 12&U 100M Medley
  ...

  Notes:
  - Place number is first token on entry line (no label)
  - Swimmer: "Last, First [MI] (age)(TEAM)"
  - Two times follow: seed, final
  - Points last
  - DQ entries: "DQ  Name (age)(TEAM)  seed  DQ"
*/

function parseMeetPage(text) {
  debugLog = [];
  const lines = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n').map(l=>l.trim()).filter(Boolean);
  const meet = { meetName:'', daAbbr:'', oppName:'', daScore:null, oppScore:null, teams:[], events:[] };

  // ── Meet title: "2025 Week 1 Dual Meet TeamA at TeamB"
  for (const l of lines) {
    if (/week\s*\d/i.test(l) && /meet/i.test(l)) {
      meet.meetName = l.replace(/\s+/g,' ').trim();
      break;
    }
  }
  debugLog.push('Meet title: ' + meet.meetName);

  // ── Team scores — handle both same-line and next-line formats
  for (let i=0; i<lines.length; i++) {
    const l = lines[i];
    // Same-line: "TeamName (AB)  405.5"
    const sameLine = l.match(/^([A-Z][A-Za-z\s&.'\-]+?)\s*\(([A-Z]{1,3})\)\s*[\t\s]+(\d+\.?\d*)$/);
    if (sameLine) {
      const name=sameLine[1].trim(), abbr=sameLine[2], score=parseFloat(sameLine[3]);
      if (!meet.teams.find(t=>t.abbr===abbr)) meet.teams.push({name, abbr, score});
      continue;
    }
    // Split-line: "TeamName (AB)" then score on next line
    const nameOnly = l.match(/^([A-Z][A-Za-z\s&.'\-]+?)\s*\(([A-Z]{1,3})\)\s*$/);
    if (nameOnly) {
      const name=nameOnly[1].trim(), abbr=nameOnly[2];
      const next = lines[i+1]?.trim();
      if (next && /^\d+\.?\d*$/.test(next) && !meet.teams.find(t=>t.abbr===abbr)) {
        meet.teams.push({name, abbr, score:parseFloat(next)});
      }
    }
  }
  debugLog.push('Teams: ' + JSON.stringify(meet.teams));

  // ── Events
  // Header: "Event N - [Male/Female] [AgeGroup] [Distance]M [Stroke]"
  //    or   "Event N - [Male/Female] [AgeGroup] [Distance]M [Stroke]"
  const eventRe = /^event\s+(\d+)\s*[-–]?\s*(.+)/i;

  let cur = null;

  for (const line of lines) {
    // ── Event header?
    const evM = line.match(eventRe);
    if (evM) {
      if (cur) meet.events.push(cur);
      cur = { ...parseEventInfo(evM[2]), eventNum:+evM[1], entries:[] };
      debugLog.push(`Ev ${evM[1]}: gender=${cur.gender} age=${cur.ageGroup} dist=${cur.distance} stroke=${cur.stroke}`);
      continue;
    }

    // ── Skip column-header rows
    if (/^(seed\s*time|final\s*time|place|name|pts|points|heat|lane)\b/i.test(line)) continue;

    if (!cur) continue;

    // ── Entry line?
    // Must start with a place number or DQ/NS
    if (!/^(\d+|DQ|NS|SCR|DSQ)\b/i.test(line)) continue;

    const entry = parseEntryLine(line);
    if (entry) {
      cur.entries.push(entry);
      if (cur.entries.length <= 2) debugLog.push(`  entry: ${JSON.stringify(entry)}`);
    }
  }
  if (cur) meet.events.push(cur);

  debugLog.push(`Total events: ${meet.events.length}`);
  const daCount = meet.events.reduce((s,e)=>s+e.entries.filter(x=>x.team===meet.daAbbr).length,0);
  debugLog.push(`Total DA entries: ${daCount}`);

  return meet;
}

// ── Event header parser ───────────────────────────────────────────────────────
function parseEventInfo(str) {
  str = str.replace(/\s+/g,' ').trim();

  // Gender
  let gender='U';
  const gm = str.match(/^(female|male|girls?|boys?|mixed)/i);
  if (gm) {
    const g=gm[0].toLowerCase();
    gender = (g==='female'||g.startsWith('girl')) ? 'F' : (g==='male'||g.startsWith('boy')) ? 'M' : 'X';
    str = str.slice(gm[0].length).trim();
  }

  // Age group: "12&U", "12 & Under", "8&U", "8 & Under", "9-10", "11-12", "13-14", "15-18"
  let ageGroup='';
  const agm = str.match(/^(8\s*[&]\s*[Uu](?:nder)?|12\s*[&]\s*[Uu](?:nder)?|8U|12U|9[-–]10|11[-–]12|13[-–]14|15[-–]18)/i);
  if (agm) {
    const raw=agm[0].replace(/\s/g,'').toLowerCase();
    if (raw.startsWith('8')) ageGroup='8U';
    else if (raw.startsWith('12')) ageGroup='12U';
    else ageGroup=raw.replace(/–/g,'-').replace(/under/i,'').replace(/[^0-9\-]/g,'');
    str=str.slice(agm[0].length).trim();
  }

  // Distance: "100M", "50M", "25M"
  let distance='';
  const dm=str.match(/^(\d+)\s*[Mm]/);
  if (dm) { distance=dm[1]; str=str.slice(dm[0].length).trim(); }

  const stroke=strokeFrom(str);
  return {gender,ageGroup,distance,stroke};
}

function strokeFrom(s) {
  // Normalize PDF ligature characters (ϐ ﬁ ﬂ etc.) before matching
  s = s.replace(/[\u03B2\u03D0\uFB00-\uFB06]/g, m => (
    {'\uFB00':'ff','\uFB01':'fi','\uFB02':'fl','\uFB03':'ffi',
     '\uFB04':'ffl','\uFB05':'st','\uFB06':'st','\u03B2':'fi','\u03D0':'fi'}[m]||m));
  s = s.trim().toLowerCase();
  if (/free/i.test(s)) return 'Free';
  if (/back/i.test(s)) return 'Back';
  if (/breast/i.test(s)) return 'Breast';
  if (/fly|butterfly|butter/i.test(s)) return 'Fly';
  if (/medley|individual|\bim\b/i.test(s)) return 'IM';
  return s.charAt(0).toUpperCase()+s.slice(1);
}

// ── Entry line parser ─────────────────────────────────────────────────────────
/*
  Input examples:
    "4  Zhao, Marc (10)(DA)  1:33.07  1:34.75  2"
    "1  Joung, Joshua S (12)(WL)  1:11.82  1:12.44  6"
    "DQ  Smith, Jane (9)(DA)  45.20  DQ"
    "6  Griffith, Caleb R (9)(DA)  1:47.75  1:41.00  0"

  Strategy: extract team tag (XX) last, then work backward for times, then name.
*/
function parseEntryLine(line) {
  // 1. Place
  const placeM = line.match(/^(\d+|DQ|NS|SCR|DSQ)\s+/i);
  if (!placeM) return null;
  const place = isNaN(+placeM[1]) ? placeM[1].toUpperCase() : +placeM[1];
  let rest = line.slice(placeM[0].length).trim();

  // 2. Extract team from "(DA)" or "(WL)" pattern — last such occurrence near name
  //    Format: "Last, First [MI] (age)(TEAM)"
  //    Team is always the last parenthetical before the times
  const teamM = rest.match(/\(([A-Z]{2,3})\)(?=\s|$|\t)/);
  if (!teamM) return null;
  const team = teamM[1];

  // 3. Everything up to and including (TEAM) is the name block
  const nameEnd = rest.indexOf(teamM[0]) + teamM[0].length;
  const nameBlock = rest.slice(0, nameEnd);
  rest = rest.slice(nameEnd).trim();

  // 4. Extract just the name — strip age "(12)" and team "(DA)" from nameBlock
  //    "Zhao, Marc (10)(DA)" → "Zhao, Marc"
  const rawName = nameBlock.replace(/\(\d+\)/g,'').replace(/\([A-Z]{2,3}\)/g,'').trim();
  const name = flipName(rawName);

  // 5. Parse times from rest — could be tabs or spaces
  //    Expect: seedTime  finalTime  points
  //    or:     seedTime  DQ
  const tokens = rest.split(/\s{2,}|\t+/).map(s=>s.trim()).filter(Boolean);
  const timeRe = /^((?:\d+:)?\d{1,2}\.\d{2})$/;
  const dqRe   = /^(DQ|NS|SCR|DSQ)$/i;
  // Points: a plain integer (no colon, no decimal point in the swimmer-time sense)
  // It appears as the LAST token after all times. Values 0-6 per event.
  const ptsRe  = /^\d+$/;

  let seedSec=null, finalSec=null, finalStr='', points=0;

  const timeTokens = tokens.filter(t=>timeRe.test(t));
  const dqTokens   = tokens.filter(t=>dqRe.test(t));

  if (timeTokens.length>=2) {
    seedSec  = sec(timeTokens[0]);
    finalSec = sec(timeTokens[1]);
    finalStr = timeTokens[1];
  } else if (timeTokens.length===1) {
    if (dqTokens.length) {
      seedSec  = sec(timeTokens[0]);
      finalStr = dqTokens[0].toUpperCase();
    } else {
      finalSec = sec(timeTokens[0]);
      finalStr = timeTokens[0];
    }
  }

  // Points = last token that is a plain integer (after times are accounted for)
  const lastToken = tokens[tokens.length-1];
  if (lastToken && ptsRe.test(lastToken) && !timeRe.test(lastToken)) {
    points = parseInt(lastToken, 10);
  }

  return {place, name, team, seedSec, finalSec, finalStr, points};
}

// ── Drops PDF parser ──────────────────────────────────────────────────────────
// For PDF mode: returns { "First Last": { "Free":sec, "Back":sec, ... } }

async function generate() {
  clearError(); showWarnings([]);
  document.getElementById('output-section').className='';
  debugLog=[];

  let meetText='';
  let isBmeet = (mode==='pdf');

  if (mode==='paste') {
    meetText=document.getElementById('paste-input').value;
    if (meetText.trim().length<50){showError('Please paste the meet results first.');return;}
    isBmeet = false; // Paste mode is always A-meet
    const aRecap = document.getElementById('a-recap-team').value;
    if (!aRecap){showError('Please select which team to generate the recap for.');return;}
  } else {
    // B-Meet PDF mode
    if (!pdfText.bmeet){showError('Please upload the B-Meet Summary PDF.');return;}
    const homeAbbr = document.getElementById('b-home-team').value;
    const awayAbbr = document.getElementById('b-away-team').value;
    if (!homeAbbr){showError('Please select the home team.');return;}
    if (!awayAbbr){showError('Please select the away team.');return;}
    if (homeAbbr===awayAbbr){showError('Home and away teams must be different.');return;}
    isBmeet = true;
  }

  document.getElementById('gen-btn').disabled=true;
  setProgress('Parsing meet results…');

  try {
    let meet;
    if (mode==='paste') {
      meet = parseMeetPage(meetText);
      // Apply user's team selection
      const aRecap = document.getElementById('a-recap-team').value;
      const aHome  = document.getElementById('a-home-team').value;
      const aAway  = document.getElementById('a-away-team').value;
      meet.daAbbr  = aRecap;
      const oppAbbr  = aRecap === aHome ? aAway : aHome;
      const recapTeam = meet.teams.find(t=>t.abbr===aRecap);
      const oppTeam   = meet.teams.find(t=>t.abbr===oppAbbr);
      meet.oppName  = oppTeam?.name  || MCSL_TEAMS.find(t=>t.abbr===oppAbbr)?.name  || oppAbbr;
      meet.daScore  = recapTeam?.score ?? null;
      meet.oppScore = oppTeam?.score  ?? null;
    } else if (isBmeet && mode==='pdf') {
      const homeAbbr = document.getElementById('b-home-team').value;
      const awayAbbr = document.getElementById('b-away-team').value;
      const recapAbbr = document.getElementById('b-recap-team').value;
      const homeName = MCSL_TEAMS.find(t=>t.abbr===homeAbbr)?.name || homeAbbr;
      const awayName = MCSL_TEAMS.find(t=>t.abbr===awayAbbr)?.name || awayAbbr;
      // Opponent is whichever team is NOT the recap team
      const oppAbbr = recapAbbr === homeAbbr ? awayAbbr : homeAbbr;
      const oppName = MCSL_TEAMS.find(t=>t.abbr===oppAbbr)?.name || oppAbbr;
      const fmt = detectBmeetFormat(pdfText.bmeet);
      debugLog.push('B-Meet format detected: ' + fmt);
      if (fmt === 'results') {
        meet = parseBmeetResultsPDF(pdfText.bmeet, recapAbbr, MCSL_TEAMS.find(t=>t.abbr===recapAbbr)?.name||recapAbbr, oppAbbr, oppName);
        // Override home/away for title: home team is always homeAbbr
        meet._homeAbbr = homeAbbr;
        meet._awayAbbr = awayAbbr;
      } else {
        meet = parseBmeetPDF(pdfText.bmeet, recapAbbr, MCSL_TEAMS.find(t=>t.abbr===recapAbbr)?.name||recapAbbr, oppAbbr, oppName);
        meet._homeAbbr = homeAbbr;
        meet._awayAbbr = awayAbbr;
      }
    } else {
      meet = parseMeetPage(meetText); // fallback
    }
    setProgress('Computing recap…');
    const recap=buildRecap(meet,isBmeet);
    document.getElementById('debug-box').textContent=debugLog.join('\n');
    document.getElementById('recap-box').textContent=recap;
    document.getElementById('output-section').className='show';
    hideProgress();
  } catch(e) {
    hideProgress();
    showError('Error: '+e.message);
    console.error(e);
    document.getElementById('debug-box').textContent=debugLog.join('\n')+'\n\nERROR: '+e.stack;
    document.getElementById('output-section').className='show';
    document.getElementById('recap-box').textContent='';
  }
  document.getElementById('gen-btn').disabled=false;
}


// ── B-Meet PDF parser (HY-TEK Meet Manager Summary format) ───────────────────
/*
  Format per swimmer:
    N  Last, First - Female - Age: 14 - ID#: XXXXXXXXXX
    #5 Women 15-18 100 IM Finals  1:25.50  1:24.27  (5)  *
    #15 Women 15-18 100 Free Finals  1:16.07  1:15.96  (4)  *

  We parse:
  - Swimmer name (flip Last, First → First Last)
  - Gender from "Male"/"Female"
  - Age → derive age group
  - Each event line: event name, seed time, final time
    * = time drop (used as confirmation but we compute ourselves)
    NT = no seed time
    DQ/NS = no final time

  Returns a meet object in the same shape as parseMeetPage output
  so buildRecap works unchanged.
*/
function parseBmeetPDF(text, homeAbbr, homeName, awayAbbr, awayName) {
  debugLog = [];
  const lines = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n').map(l=>l.trim()).filter(Boolean);

  // Extract meet title from header line
  // "2026-06-17 - Week 1B vs Clarksburg Village - 6/17/2026"
  let meetTitle = '';
  for (const l of lines) {
    const m = l.match(/(\d{4}-\d{2}-\d{2}\s*-\s*.+?)\s*-\s*\d{1,2}\/\d{1,2}\/\d{4}/);
    if (m) { meetTitle = m[1].trim(); break; }
  }
  // Fallback: first non-header line that looks like a title
  if (!meetTitle) {
    for (const l of lines) {
      if (/week/i.test(l) && l.length < 80) { meetTitle = l; break; }
    }
  }
  debugLog.push('B-Meet title: ' + meetTitle);

  // Extract week number and letter from title
  // "Week 1B" or "Week 1 B" or just use what's in the title
  const weekM = meetTitle.match(/week\s*(\d+)\s*([AB])?/i);
  const weekNum = weekM ? weekM[1] : '?';
  const weekLetter = weekM && weekM[2] ? weekM[2].toUpperCase() : 'B';

  const meet = {
    meetName: meetTitle,
    daAbbr: homeAbbr,   // DA = home team whose swimmers are listed
    oppName: awayName,
    daScore: null,
    oppScore: null,
    teams: [
      {name: homeName, abbr: homeAbbr, score: null},
      {name: awayName, abbr: awayAbbr, score: null}
    ],
    events: [],
    // Store week info for title formatting
    _weekNum: weekNum,
    _weekLetter: weekLetter,
  };

  // ── Parse swimmer blocks ──────────────────────────────────────────────────
  // Swimmer header: "N  Last, First - Female - Age: 14 - ID#: ..."
  //   or with middle name handling: "Fensterseifer Fideli, Benjamin Fideli - Male - Age: 9"
  const swimmerRe = /^\d+\s+([A-Z][A-Za-z\s,'-]+?)\s*-\s*(Male|Female)\s*-\s*Age:\s*(\d+)/i;
  // Event line: "#5 Women 15-18 100 IM Finals  1:25.50  1:24.27  (5)  *"
  const eventRe  = /^#(\d+)\s+(.+?)\s+Finals\s+(\S+)\s+(\S+)(?:\s+\((\d+)\))?/i;

  let curSwimmer = null; // {name, gender, age, ageGroup}

  for (const line of lines) {
    // Swimmer header?
    const sm = line.match(swimmerRe);
    if (sm) {
      const rawName = sm[1].trim();
      const gender  = /female/i.test(sm[2]) ? 'F' : 'M';
      const age     = parseInt(sm[3]);
      curSwimmer = {
        name: flipName(rawName),
        gender,
        age,
        ageGroup: ageGroupFromAge(age),
      };
      debugLog.push(`Swimmer: ${curSwimmer.name} ${curSwimmer.gender} age ${age} → ${curSwimmer.ageGroup}`);
      continue;
    }

    if (!curSwimmer) continue;

    // Event line?
    const em = line.match(eventRe);
    if (!em) continue;

    const eventDesc = em[2].trim();   // "Women 15-18 100 IM"
    const seedStr   = em[3].trim();
    const finalStr  = em[4].trim();
    const place     = em[5] ? parseInt(em[5]) : null;

    const seedSec  = /^(NT|NR)$/i.test(seedStr)  ? null : sec(seedStr);
    const finalSec = /^(DQ|NS|SCR|EXH)$/i.test(finalStr) ? null : sec(finalStr);
    if (!finalSec) continue; // skip non-finishers

    // Parse event descriptor to get stroke, distance, ageGroup
    const evInfo = parseEventDesc(eventDesc);
    if (!evInfo.stroke) continue;

    // Find or create event bucket (we group by stroke+ageGroup+gender+distance)
    const evKey = `${evInfo.gender||curSwimmer.gender}|${evInfo.ageGroup||curSwimmer.ageGroup}|${evInfo.distance}|${evInfo.stroke}`;
    let ev = meet.events.find(e=>e._key===evKey);
    if (!ev) {
      ev = {
        _key: evKey,
        gender: evInfo.gender || curSwimmer.gender,
        ageGroup: evInfo.ageGroup || curSwimmer.ageGroup,
        distance: evInfo.distance,
        stroke: evInfo.stroke,
        eventNum: parseInt(em[1]),
        entries: []
      };
      meet.events.push(ev);
    }

    ev.entries.push({
      place,
      name: curSwimmer.name,
      team: homeAbbr,
      seedSec,
      finalSec,
      finalStr: finalStr,
      points: 0  // B-meets don't score
    });
  }

  debugLog.push(`B-Meet events: ${meet.events.length}`);
  debugLog.push(`B-Meet total entries: ${meet.events.reduce((s,e)=>s+e.entries.length,0)}`);
  return meet;
}

// Map swimmer age to MCSL age group string
function ageGroupFromAge(age) {
  if (age <= 6)  return '6U';
  if (age <= 8)  return '8U';
  if (age <= 10) return '9-10';
  if (age <= 12) return '11-12';
  if (age <= 14) return '13-14';
  return '15-18';
}

// Parse event descriptor like "Women 15-18 100 IM" or "Men 9-10 25 Back"
// Also handles "Mixed 12&U 100 IM", "Women 6&U 25 Free", "Men 7-8 25 Free"
function parseEventDesc(str) {
  str = str.replace(/\s+/g,' ').trim();
  let gender = 'U';
  const gm = str.match(/^(women|men|mixed|girls?|boys?)/i);
  if (gm) {
    const g = gm[0].toLowerCase();
    gender = (g==='women'||g.startsWith('girl')) ? 'F' : (g==='men'||g.startsWith('boy')) ? 'M' : 'X';
    str = str.slice(gm[0].length).trim();
  }
  let ageGroup = '';
  // Handle "7-8" as "8U", "6&U"/"6U" as "6U", standard groups
  const agm = str.match(/^(6\s*[&]?\s*[Uu](?:nder)?|6U|7[-–]8|8\s*[&]\s*[Uu](?:nder)?|8U|12\s*[&]\s*[Uu](?:nder)?|12U|9[-–]10|11[-–]12|13[-–]14|15[-–]18)/i);
  if (agm) {
    const raw = agm[0].replace(/\s/g,'').toLowerCase();
    if (raw.startsWith('6')||raw==='7-8'||raw==='78') ageGroup='8U';  // 6&U and 7-8 both map to 8U for allstar
    else if (raw.startsWith('8')) ageGroup='8U';
    else if (raw.startsWith('12')) ageGroup='12U';
    else ageGroup = raw.replace(/[–]/g,'-').replace(/under/,'').replace(/[^0-9\-]/g,'');
    str = str.slice(agm[0].length).trim();
  }
  const dm = str.match(/^(\d+)\s*[Mm]?/);
  const distance = dm ? dm[1] : '';
  if (dm) str = str.slice(dm[0].length).trim();
  const stroke = strokeFrom(str);
  return {gender, ageGroup, distance, stroke};
}


// ── B-Meet format detection ────────────────────────────────────────────────────
function detectBmeetFormat(text) {
  // Results format: event-first, full team names inline, "Results - All Events"
  if (/Results\s*-\s*All Events/i.test(text)) return 'results';
  if (/^Event\s+\d+\s+(Boys|Girls|Men|Women|Mixed)\s+/im.test(text)) return 'results';
  // Summary format: swimmer-first, ID# fields, "#N Event Finals" lines
  if (/ID#:/i.test(text) && /#\d+\s+(Men|Women)/i.test(text)) return 'summary';
  // Fallback: if we see "Finals" with event number prefix, it's summary
  if (/#\d+\s+\w+.*Finals/i.test(text)) return 'summary';
  return 'unknown';
}

// ── Resolve a full team name like "Flower Valley Frogs" to an MCSL abbr ────────
function resolveTeamAbbr(fullName) {
  // Strip common swim team suffixes
  const cleaned = fullName
    .replace(/\s*(swim\s*team.*|frogs|dolphins|sharks|marlins|swim\s*club|aquatics?|sc|barracudas?|stingrays?|sea\s*hawks?|waves?|tidal\s*waves?|-PV|-MD)\s*$/i, '')
    .trim().toLowerCase();
  let best = null, bestScore = 0;
  for (const t of MCSL_TEAMS) {
    const tname = t.name.toLowerCase();
    if (tname === cleaned) return t.abbr;
    if (cleaned.startsWith(tname) || tname.startsWith(cleaned)) {
      const score = Math.min(tname.length, cleaned.length);
      if (score > bestScore) { bestScore = score; best = t.abbr; }
    }
    // Also try word overlap: count matching words
    const twords = tname.split(/\s+/);
    const cwords = cleaned.split(/\s+/);
    const overlap = twords.filter(w => cwords.includes(w)).length;
    if (overlap >= 2 && overlap > bestScore - 10) {
      bestScore = overlap + 10;
      best = t.abbr;
    }
  }
  return best || fullName.slice(0,3).toUpperCase();
}

// ── B-Meet Results format parser (HY-TEK Results report) ─────────────────────
/*
  Format:
    Week 2B DA at FV - 6/24/2026
    Results - All Events
    Event 1 Boys 12 & Under 100 SC Meter IM
    1:20.00 ALL*
    Name Age Team Seed Time Finals Time
    1 Benedetti, Brady 11 Flower Valley Frogs 1:29.45 1:28.56
    3 Smith, John     11 Home Swim Team-PV 1:37.76 1:35.14
    --- Kissam, Kaia  10 Flower Valley Frogs 1:38.25 DQ
    (Event 3 Boys 13-14 100 SC Meter IM)   ← page-continuation header, skip
*/
function parseBmeetResultsPDF(text, homeAbbr, homeName, awayAbbr, awayName) {
  debugLog = [];
  // Normalize ligature characters and collapse mid-word tab splits before parsing
  const _lig = {
    'ﬀ':'ff','ﬁ':'fi','ﬂ':'fl','ﬃ':'ffi',
    'ﬄ':'ffl','ﬅ':'st','ﬆ':'st',
    'β':'fi','ϐ':'fi'  // β (U+03B2) and ϐ (U+03D0) both used by HY-TEK PDFs
  };
  const _ligRe = /[ﬀ-ﬆβϐ]/g;
  const cleanLine = l => {
    // Step 1: expand ligature characters (ϐ ﬁ ﬂ etc.)
    l = l.replace(_ligRe, m => _lig[m]||m);
    // Step 2: remove space-only and double tab artifacts from PDF.js column extraction
    l = l.replace(/\t +\t/g,'\t').replace(/\t\t+/g,'\t');
    // Step 3: collapse short letter fragments separated by tabs (ligature split artifacts)
    // Allow comma at end of fragment and space in lookahead (for "Last, First" names)
    for (let i=0; i<4; i++)
      l = l.replace(/([A-Za-z]{1,8})\t([A-Za-z]{1,4},?)(?=\t| |$)/g, (_,a,b)=>a+b);
    // Step 4: fix double-vowel artifacts from ligature expansion + merging
    l = l.replace(/([fl])ii/gi,'$1i').replace(/([fl])ll/gi,'$1l');
    return l;
  };
  const rawLines = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n').map(l=>l.trim()).filter(Boolean);
  const lines = rawLines.map(cleanLine).filter(Boolean);
  // Debug: log any line containing a raw ligature char or "Grif"
  rawLines.forEach((raw,i) => {
    if (/[\u03B2\u03D0\uFB00-\uFB06]/.test(raw) || raw.includes('Grif')) {
      debugLog.push('RAW['+i+']: '+JSON.stringify(raw));
      debugLog.push('CLN['+i+']: '+JSON.stringify(lines[i]||'(filtered)'));
    }
  });

  // Title: "Week 2B DA at FV - 6/24/2026"
  let meetTitle = '';
  for (const l of lines) {
    if (/week\s*\d/i.test(l) && l.length < 80) { meetTitle = l.replace(/\s*-\s*\d{1,2}\/\d{1,2}\/\d{4}.*$/,'').trim(); break; }
  }
  const weekM = meetTitle.match(/week\s*(\d+)\s*([AB])?/i);
  const weekNum = weekM ? weekM[1] : '?';
  const weekLetter = weekM && weekM[2] ? weekM[2].toUpperCase() : 'B';

  const meet = {
    meetName: meetTitle,
    daAbbr: homeAbbr,
    oppName: awayName,
    daScore: null, oppScore: null,
    teams: [
      {name: homeName, abbr: homeAbbr, score: null},
      {name: awayName, abbr: awayAbbr, score: null}
    ],
    events: [],
    _weekNum: weekNum,
    _weekLetter: weekLetter,
  };

  const evHeaderRe  = /^Event\s+(\d+)\s+(Boys|Girls|Men|Women|Mixed)\s+(.+)/i;
  const evContRe    = /^\(Event\s+\d+/i;  // "(Event 3 ...)" continuation header — skip
  // Entry: place  Last, First [words]  age(1-2 digits)  Team Name(multi-word)  seed  final
  const entryRe = /^(\*?\d+|---)\s+(.+?)\s+(\d{1,2})\s+([A-Za-z][\w\s'.,\-]+?)\s+(NT|\d+:\d+\.\d+|\d+\.\d+)\s+(DQ|NS|SCR|\d+:\d+\.\d+|\d+\.\d+)\s*$/i;

  let curEvent = null;

  for (const line of lines) {
    // Skip continuation headers "(Event N ...)"
    if (evContRe.test(line)) continue;
    // Skip ALL* standard lines, column headers, page headers
    if (/^(\d+:\d+\.\d+|\d+\.\d+)\s+ALL/i.test(line)) continue;
    if (/^(Name|Place)\s+Age/i.test(line)) continue;
    if (/^MCSL\s*-/i.test(line)) continue;
    if (/^Results\s*-/i.test(line)) continue;

    // Event header?
    const evM = line.match(evHeaderRe);
    if (evM) {
      const genderWord = evM[2];
      const gender = /^(girls?|women)/i.test(genderWord) ? 'F' : 'M';
      const desc = genderWord + ' ' + evM[3];
      const evInfo = parseEventDesc(desc);
      // Use a unique key: gender+ageGroup+distance+stroke (handles duplicate event numbers)
      const evKey = `${evInfo.gender||gender}|${evInfo.ageGroup}|${evInfo.distance}|${evInfo.stroke}`;
      // Avoid duplicate keys from page breaks re-emitting same event
      curEvent = meet.events.find(e=>e._key===evKey);
      if (!curEvent) {
        curEvent = {
          _key: evKey,
          gender: evInfo.gender || gender,
          ageGroup: evInfo.ageGroup,
          distance: evInfo.distance,
          stroke: evInfo.stroke,
          eventNum: parseInt(evM[1]),
          entries: []
        };
        meet.events.push(curEvent);
      }
      debugLog.push(`Ev ${evM[1]}: ${evKey}`);
      continue;
    }

    if (!curEvent) continue;

    // Entry row?
    const em = line.match(entryRe);
    if (!em) continue;

    const placeStr  = em[1];
    const rawName   = em[2].trim();
    const age       = parseInt(em[3]);
    const teamFull  = em[4].trim();
    const seedStr   = em[5].trim();
    const finalStr  = em[6].trim();

    const place   = /^\*?(\d+)$/.test(placeStr) ? parseInt(placeStr.replace('*','')) : placeStr;
    const name    = flipName(rawName);
    const teamAbbr = resolveTeamAbbr(teamFull);
    const seedSec  = /^(NT|NR)$/i.test(seedStr)  ? null : sec(seedStr);
    const finalSec = /^(DQ|NS|SCR)$/i.test(finalStr) ? null : sec(finalStr);

    if (!finalSec) continue; // skip DQ/NS

    curEvent.entries.push({
      place, name, team: teamAbbr,
      seedSec, finalSec, finalStr,
      points: 0
    });
  }

  debugLog.push(`Results-format events: ${meet.events.length}`);
  debugLog.push(`Results-format total entries: ${meet.events.reduce((s,e)=>s+e.entries.length,0)}`);
  return meet;
}

// ── Recap builder ─────────────────────────────────────────────────────────────
function buildRecap(meet, isBmeet=false) {
  const {meetName,daAbbr,oppName,daScore,oppScore,events}=meet;

  // Build swimmer map: name → {gender,ageGroup,totalPoints,firstPlaces,results[]}
  const swimmerMap={};

  for (const ev of events) {
    for (const en of ev.entries) {
      if (en.team!==daAbbr) continue;
      if (!en.finalSec||en.finalSec<=0) continue;

      if (!swimmerMap[en.name]) {
        swimmerMap[en.name]={gender:ev.gender,ageGroup:ev.ageGroup,totalPoints:0,firstPlaces:0,results:[]};
      }
      const sw=swimmerMap[en.name];
      sw.totalPoints+=en.points;
      if (en.place===1) sw.firstPlaces++;

      // Seed: from inline data (paste) or B-meet PDF parser
      let seedSec=en.seedSec;

      sw.results.push({
        stroke:ev.stroke, distance:ev.distance,
        ageGroup:ev.ageGroup, gender:ev.gender,
        finalSec:en.finalSec, finalStr:en.finalStr,
        seedSec, place:en.place
      });
    }
  }

  debugLog.push(`DA swimmers: ${Object.keys(swimmerMap).length}`);
  if (Object.keys(swimmerMap).length>0)
    debugLog.push('Sample: '+JSON.stringify(Object.entries(swimmerMap)[0]));

  // ── Drops
  // allDropEvents: every individual event drop (d>0), used for PBs and biggest drop
  // swimmerEventDrops: name → [{stroke, dropSec}] — one entry per event
  // For Most Improved: count distinct strokes with ANY drop (d>0), combine totals
  // For drop buckets: each individual event drop checked independently against ≥2s floor
  const allDropEvents=[];       // {name, stroke, dropSec} — all positive drops
  const swimmerEventDrops={};   // name → [{stroke, dropSec}]

  for (const [name,sw] of Object.entries(swimmerMap)) {
    swimmerEventDrops[name]=[];
    for (const r of sw.results) {
      if (r.seedSec&&r.seedSec>0&&r.finalSec>0) {
        const d=r.seedSec-r.finalSec;
        if (d>0) {
          swimmerEventDrops[name].push({stroke:r.stroke, dropSec:d});
          allDropEvents.push({name, stroke:r.stroke, dropSec:d});
        }
      }
    }
  }

  // Combined drop per swimmer — for Most Improved
  // strokes = distinct stroke names where swimmer dropped (by any amount)
  // total   = sum of all individual drops across all events
  const combinedDrop={};
  for (const [name,drops] of Object.entries(swimmerEventDrops)) {
    if (!drops.length) continue;
    const total=drops.reduce((s,e)=>s+e.dropSec,0);
    const strokes=[...new Set(drops.map(e=>e.stroke))];
    combinedDrop[name]={total, strokes};
  }

  // Drop buckets — each individual event drop evaluated independently
  // floor-second bucketing: 2.00-2.99=2, 3.00-3.99=3, etc. Only ≥2s shown.
  const bucketEntries=[]; // {name, stroke, dropSec} for all drops ≥2s
  for (const [name,drops] of Object.entries(swimmerEventDrops)) {
    for (const {stroke,dropSec} of drops) {
      if (dropSec>=2) bucketEntries.push({name,stroke,dropSec});
    }
  }

  // ── All-Star qualifiers
  const quals=[];
  const qualSeen=new Set();
  for (const ev of events) {
    for (const en of ev.entries) {
      if (en.team!==daAbbr||!en.finalSec||en.finalSec<=0) continue;
      const key=`${ev.ageGroup}|${ev.stroke}`;
      const std=ALLSTAR[key];
      if (!std) continue;
      const g=ev.gender==='F'?'F':'M';
      const cut=std[g];
      if (cut&&en.finalSec<=cut) {
        const qk=en.name+'|'+key;
        if (!qualSeen.has(qk)){
          qualSeen.add(qk);
          quals.push({name:en.name,event:`${ev.distance}M ${ev.stroke}`,time:en.finalStr,stroke:ev.stroke});
        }
      }
    }
  }

  // ── Personal bests
  const pbCount=allDropEvents.length;
  const biggest=allDropEvents.sort((a,b)=>b.dropSec-a.dropSec)[0]||null;

  // ── Drop buckets (already computed above as bucketEntries)
  const buckets={};
  for (const {name,stroke,dropSec} of bucketEntries) {
    const b=Math.floor(dropSec);
    if (!buckets[b])buckets[b]=[];
    buckets[b].push({name,stroke});
  }

  // ── Top scorers
  function topScore(list) {
    if (!list.length) return null;
    const top=list[0][1].totalPoints;
    const tied=list.filter(([,v])=>v.totalPoints===top);
    return {names:tied.map(([n])=>n),pts:top,fp:tied[0][1].firstPlaces};
  }
  const girls=Object.entries(swimmerMap).filter(([,v])=>v.gender==='F').sort((a,b)=>b[1].totalPoints-a[1].totalPoints);
  const boys =Object.entries(swimmerMap).filter(([,v])=>v.gender==='M').sort((a,b)=>b[1].totalPoints-a[1].totalPoints);
  const topG=topScore(girls), topB=topScore(boys);

  // Most improved: 3+ event drops, top 5 by combined total
  const mostImproved=Object.entries(combinedDrop)
    .filter(([,info])=>info.strokes.length>=3)
    .sort((a,b)=>b[1].total-a[1].total)
    .slice(0,5);

  // ── Warnings
  const warns=[];
  if (events.length===0) warns.push('No events detected — format may not match expected MCSL layout.');
  if (Object.keys(swimmerMap).length===0) warns.push(`No ${daAbbr} swimmer entries found.`);
  const seedCount=Object.values(swimmerEventDrops).reduce((s,arr)=>s+arr.length,0);
  if (seedCount===0&&Object.keys(swimmerMap).length>0)
    warns.push('No seed times found — drops section will be empty. Check that the results page includes a Seed Time column.');
  showWarnings(warns);

  // ── Format helpers
  const nameList=arr=>arr.length<=1?arr[0]:arr.slice(0,-1).join(', ')+' and '+arr.slice(-1)[0];
  const strokeList=arr=>{
    const u=[...new Set(arr)];
    if(u.length===1)return u[0];
    if(u.length===2)return u[0]+' and '+u[1];
    return u.slice(0,-1).join(', ')+', and '+u.slice(-1)[0];
  };

  // ── Build output string
  let o='';
  const mName=meetName||'Meet Recap';
  const da=daScore!==null?daScore:'???';
  const os=oppScore!==null?oppScore:'???';
  const opp=oppName?oppName.toUpperCase():'OPPONENT';

  // Format title: extract week number and A/B designation
  // meetName e.g. "2025 Week 1 Dual Meet TeamA at TeamB" or "2025 Week 1A Dual Meet..."
  const weekM = mName.match(/week\s*(\d+)\s*([AB])?/i);
  const weekNum = meet._weekNum || (weekM ? weekM[1] : '?');
  const weekLetter = meet._weekLetter || (weekM && weekM[2] ? weekM[2].toUpperCase() : (isBmeet ? 'B' : 'A'));
  const daName = (MCSL_TEAMS.find(t=>t.abbr===daAbbr)?.name || daAbbr).toUpperCase();
  let formattedTitle;
  if (isBmeet) {
    // Use _homeAbbr/_awayAbbr if set (Results format preserves actual home/away)
    const homeAbbr = meet._homeAbbr || daAbbr;
    const awayAbbr = meet._awayAbbr || (meet.teams?.find(t=>t.abbr!==homeAbbr)?.abbr);
    const homeName = (MCSL_TEAMS.find(t=>t.abbr===homeAbbr)?.name || homeAbbr).toUpperCase();
    const awayName = (MCSL_TEAMS.find(t=>t.abbr===awayAbbr)?.name || awayAbbr || opp).toUpperCase();
    formattedTitle = `Week ${weekNum} B-Meet: ${awayName} at ${homeName}`;
  } else {
    formattedTitle = `Week ${weekNum} ${weekLetter}-Meet: ${daName} (${da}) VS ${opp} (${os})`;
  }
  o+=formattedTitle+'\n\n';

  o+=`Top 5 Most Improved (3+ Events)\n`;
  if (mostImproved.length) {
    for (const [name,info] of mostImproved)
      o+=`${name} dropped a combined ${info.total.toFixed(2)} seconds across ${strokeList(info.strokes)}\n`;
  } else { o+=`(No seed time data available)\n`; }
  o+='\n';

  if (!isBmeet) {
    o+=`Top Point Scorers\n`;
    if (topG) {
      const fp=topG.fp;
      const each=topG.names.length>1?' each':'';
      o+=`Girls - ${nameList(topG.names)} with ${topG.pts} points and ${fp} first place finish${fp!==1?'es':''}${each}\n`;
    }
    if (topB) {
      const fp=topB.fp;
      const each=topB.names.length>1?' each':'';
      o+=`Boys - ${nameList(topB.names)} with ${topB.pts} points and ${fp} first place finish${fp!==1?'es':''}${each}\n`;
    }
    if (!topG&&!topB) o+=`(No scoring data found)\n`;
    o+='\n';
  }

  o+=`All-Star Qualifiers\n`;
  if (quals.length) {
    for (const q of quals) o+=`${q.name} - ${q.event} - ${q.time}\n`;
  } else { o+=`(None this meet)\n`; }
  o+='\n';

  o+=`Personal Bests\n`;
  o+=`We had ${pbCount} new personal best${pbCount!==1?'s':''} across the team.\n`;
  if (biggest) o+=`\nBiggest single-event drop: ${biggest.name} dropped ${biggest.dropSec.toFixed(2)} in ${biggest.stroke}\n`;
  o+='\n';

  const maxB=Object.keys(buckets).length?Math.max(...Object.keys(buckets).map(Number)):1;
  for (let b=2;b<=maxB;b++) {
    if (!buckets[b]||!buckets[b].length) continue;
    o+=`${b}-Second Drops\n`;
    for (const e of buckets[b]) o+=`${e.name} - ${e.stroke}\n`;
    o+='\n';
  }

  return o.trimEnd();
}

// ── Export ────────────────────────────────────────────────────────────────────
function copyRecap(){
  navigator.clipboard.writeText(document.getElementById('recap-box').textContent).then(()=>{
    const b=document.querySelector('.btn-copy');b.textContent='Copied!';
    setTimeout(()=>b.textContent='Copy Text',2000);
  });
}
