// ── UI ────────────────────────────────────────────────────────────────────────
function setMode(m) {
  mode=m;
  document.getElementById('mode-paste').style.display=m==='paste'?'':'none';
  document.getElementById('mode-pdf').style.display=m==='pdf'?'':'none';
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('active',t.dataset.mode===m));
}
function onPasteInput() {
  const ta=document.getElementById('paste-input');
  const has=ta.value.trim().length>50;
  ta.classList.toggle('has-content',has);
  const st=document.getElementById('paste-status');
  if(has){
    st.textContent='✓ Content ready';st.className='file-status show ok';
    populateAMeetTeamSelectors(ta.value);
  } else {
    st.className='file-status';
    document.getElementById('a-team-selectors').style.display='none';
  }
}

function populateAMeetTeamSelectors(text) {
  // Reuse existing team detection logic from parseMeetPage
  const teams = [];
  const seen = new Set();
  const normalized = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n');
  const sLines = normalized.split('\n').map(l=>l.trim()).filter(Boolean);

  for (let i=0; i<sLines.length; i++) {
    const l = sLines[i];
    // Same-line score: "TeamName (AB)  405.5"
    const sameLine = l.match(/^([A-Z][A-Za-z\s&.'\-]+?)\s*\(([A-Z]{1,3})\)\s*[	\s]+(\d+\.?\d*)$/);
    if (sameLine) {
      const abbr=sameLine[2], name=sameLine[1].trim();
      if (!seen.has(abbr)) { seen.add(abbr); teams.push({abbr, name}); }
      continue;
    }
    // Split-line score: "TeamName (AB)" then score on next line
    const nameOnly = l.match(/^([A-Z][A-Za-z\s&.'\-]+?)\s*\(([A-Z]{1,3})\)\s*$/);
    if (nameOnly) {
      const abbr=nameOnly[2], name=nameOnly[1].trim();
      const next = sLines[i+1]?.trim();
      if (next && /^\d+\.?\d*$/.test(next) && !seen.has(abbr)) {
        seen.add(abbr); teams.push({abbr, name});
      }
    }
  }

  if (teams.length < 2) {
    document.getElementById('a-team-selectors').style.display='none';
    return;
  }

  const opts = teams.map(t=>`<option value="${t.abbr}">${t.name} (${t.abbr})</option>`).join('');
  document.getElementById('a-home-team').innerHTML = '<option value="">Select home team…</option>' + opts;
  document.getElementById('a-away-team').innerHTML  = '<option value="">Select away team…</option>'  + opts;
  document.getElementById('a-recap-team').innerHTML = '<option value="">Select team to recap…</option>' + opts;
