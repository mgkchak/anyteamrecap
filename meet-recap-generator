function populateBmeetTeamSelectors(text) {
  const fmt = detectBmeetFormat(text);
  let detectedTeams = []; // [{abbr, name}]

  if (fmt === 'results') {
    // Scan for full team names in entry rows: "Name Age TeamName seed final"
    // Collect unique team name strings then resolve to abbrs
    const lines = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n').map(l=>l.trim()).filter(Boolean);
    const entryRe = /^(\*?\d+|---)\s+(.+?)\s+(\d{1,2})\s+([A-Za-z][\w\s'.,\-]+?)\s+(NT|\d+:\d+\.\d+|\d+\.\d+)\s+(DQ|NS|SCR|\d+:\d+\.\d+|\d+\.\d+)\s*$/i;
    const teamNames = new Set();
    for (const line of lines) {
      const m = line.match(entryRe);
      if (m) teamNames.add(m[4].trim());
    }
    for (const name of teamNames) {
      const abbr = resolveTeamAbbr(name);
      if (!detectedTeams.find(t=>t.abbr===abbr)) {
        const mcslTeam = MCSL_TEAMS.find(t=>t.abbr===abbr);
        detectedTeams.push({abbr, name: mcslTeam?.name || name});
      }
    }
  } else {
    // Summary format: only one team listed (DA), the other is the opponent
    // Just show the full MCSL dropdown as before
    document.getElementById('b-team-selectors').style.display = '';
    const allOpts = MCSL_TEAMS.map(t=>`<option value="${t.abbr}">${t.name} (${t.abbr})</option>`).join('');
    document.getElementById('b-home-team').innerHTML = '<option value="">Select home team…</option>' + allOpts;
    document.getElementById('b-away-team').innerHTML = '<option value="">Select away team…</option>' + allOpts;
    document.getElementById('b-recap-team').innerHTML = '<option value="">Select team to recap…</option>' + allOpts;
    return;
  }

  if (detectedTeams.length < 2) {
    // Fallback: show full dropdown
    document.getElementById('b-team-selectors').style.display = '';
    const allOpts = MCSL_TEAMS.map(t=>`<option value="${t.abbr}">${t.name} (${t.abbr})</option>`).join('');
    document.getElementById('b-home-team').innerHTML = '<option value="">Select home team…</option>' + allOpts;
    document.getElementById('b-away-team').innerHTML = '<option value="">Select away team…</option>' + allOpts;
    document.getElementById('b-recap-team').innerHTML = '<option value="">Select team to recap…</option>' + allOpts;
    return;
  }

  // Populate with just the two detected teams
  const opts = detectedTeams.map(t=>`<option value="${t.abbr}">${t.name} (${t.abbr})</option>`).join('');
  document.getElementById('b-home-team').innerHTML = '<option value="">Select home team…</option>' + opts;
  document.getElementById('b-away-team').innerHTML = '<option value="">Select away team…</option>' + opts;
  document.getElementById('b-recap-team').innerHTML = '<option value="">Select team to recap…</option>' + opts;
  document.getElementById('b-team-selectors').style.display = '';
}
